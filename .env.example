# =========================================================================
# SkillBridge Backend (NestJS) — Environment Variables
# Copy to .env and fill real values. (2026-05-30: NestJS-only, no .NET.)
# =========================================================================

# ----- Server -----
NODE_ENV=development
PORT=3002
# Comma-separated FE origins allowed by CORS (public-facing backend now)
CORS_ORIGINS=http://localhost:8080

# ----- Auth (JWT — was .NET's job, now NestJS/Passport) -----
JWT_ACCESS_SECRET=change-me-strong-random
JWT_ACCESS_TTL=3600              # seconds (1h)
JWT_REFRESH_SECRET=change-me-different-strong-random
JWT_REFRESH_TTL=604800           # seconds (7d) — refresh token as HttpOnly cookie
# Google sign-in (verify id_token)
GOOGLE_CLIENT_ID=

# ----- Internal AI guard (optional) -----
# If the AI module is exposed via /internal/ai/* for any out-of-process caller,
# protect it with this secret. Intra-process service calls skip the guard.
INTERNAL_AUTH_SECRET=change-me-to-a-strong-random-string

# ----- LLM Providers -----
# Gemini — SDK = @google/genai (NEW). The old @google/generative-ai is EOL (2025).
GEMINI_API_KEY=
GEMINI_MODEL_DEFAULT=gemini-2.0-flash
GEMINI_MODEL_EMBEDDING=text-embedding-004

# OpenAI (fallback / alternative) — SDK openai v6
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o-mini
OPENAI_MODEL_EMBEDDING=text-embedding-3-small

# Default provider: "gemini" | "openai"  (final default decided by calibration)
LLM_PROVIDER_DEFAULT=gemini

# ----- Database (Postgres — NestJS OWNS it via TypeORM) -----
# TypeORM reads this. NestJS now owns ALL tables + migrations (no more .NET split).
DATABASE_URL=postgresql://user:password@localhost:5432/skillbridge?schema=public
DB_SSL=false
# Never use synchronize in shared/prod envs — migrations are the source of truth.
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false

# ----- Vector Store (pgvector inside the same Postgres) -----
VECTOR_DIMENSION=768
VECTOR_TABLE=document_chunks
VECTOR_COLUMN=embedding

# ----- File storage (CV uploads — Cloudflare R2, S3-compatible) -----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=skillbridge-cv
R2_PUBLIC_BASE_URL=

# ----- Rate limiting (@nestjs/throttler) -----
THROTTLE_TTL=60                  # seconds
THROTTLE_LIMIT=100               # requests per TTL per IP

# ----- Observability -----
LOG_LEVEL=debug
ENABLE_REQUEST_LOGGING=true
