# ----- Server -----
NODE_ENV=development
PORT=3002
INTERNAL_AUTH_SECRET=change-me-at-least-16-chars

BACKEND_PUBLIC_URL=http://localhost:3002
FRONTEND_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080,https://www.skillbridgebuilder.com

# ----- API Docs -----
API_DOCS_ENABLED=true
API_DOCS_PATH=reference
OPENAPI_JSON_PATH=openapi.json

# ----- Auth -----
JWT_ACCESS_SECRET=change-me-strong-random
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=change-me-different-strong-random
JWT_REFRESH_TTL=1209600
GOOGLE_CLIENT_ID=

# ----- Email / Resend -----
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=SkillBridge <noreply@your-verified-domain.com>
EMAIL_VERIFY_TOKEN_TTL_SECONDS=86400

# ----- LLM Providers -----
# OpenAI is the default text/embedding provider for current scoring and matching flows.
LLM_PROVIDER_DEFAULT=openai

OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-5.4-mini
OPENAI_MODEL_EMBEDDING=text-embedding-3-large
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin

# CV/JD matching: v1 is the safe baseline; set v2 only after drift/staging checks.
CV_JD_MATCH_TEMPLATE_CODE=cv_jd_match_v1

# Stabilizes repeated CV/JD scoring by caching only the LLM extraction payload.
# Disable quickly if needed: CV_JD_MATCH_EXTRACTION_CACHE_ENABLED=false
CV_JD_MATCH_EXTRACTION_CACHE_ENABLED=true

# Gemini remains available for future Gemini Live / fallback flows.
GEMINI_API_KEY=
GEMINI_MODEL_DEFAULT=gemini-2.5-flash
GEMINI_MODEL_EMBEDDING=gemini-embedding-001

# ----- Database (Postgres + pgvector) -----
# Supabase is used as the Postgres host only. Auth still belongs to this NestJS backend.
DATABASE_URL=postgres://user:password@localhost:5432/skillbridge
# Set true for Supabase hosted Postgres.
DB_SSL=false
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false

# ----- Vector / Semantic Skill Matching -----
VECTOR_DIMENSION=1024
VECTOR_TABLE=document_chunks
VECTOR_COLUMN=embedding
VECTOR_EMBEDDING_VERSION=v1
SEMANTIC_ACCEPT_THRESHOLD=0.72
SEMANTIC_REVIEW_BAND=0.08
SEMANTIC_MAX_PER_CV=16

# ----- File Storage (Google Cloud Storage) -----
# Bucket stays private; files are downloaded through authenticated API endpoints.
# On Cloud Run, auth uses ADC/service account metadata. Do not commit service account keys.
GCS_BUCKET=your-gcs-bucket-name
GCS_PROJECT_ID=

# Optional. When omitted, Puppeteer uses its bundled/default browser.
PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# ----- payOS -----
PAYMENT_PROVIDER=PAYOS
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=http://localhost:8080/billing/checkout
PAYOS_CANCEL_URL=http://localhost:8080/billing/checkout
PAYOS_WEBHOOK_URL=http://localhost:3002/api/billing/payos/webhook
PAYOS_PARTNER_CODE=

# ----- Quota / Rate Limiting -----
CV_REVIEW_DAILY_LIMIT=5
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ----- Observability -----
LOG_LEVEL=debug
ENABLE_REQUEST_LOGGING=true
