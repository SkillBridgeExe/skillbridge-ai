# =========================================================================
# SkillBridge AI Service — Environment Variables
# Copy this file to .env and fill in real values for local development.
# =========================================================================

# ----- Server -----
NODE_ENV=development
PORT=3002

# ----- Internal Auth (.NET <-> NestJS) -----
# Shared secret between .NET BFF and this service.
# .NET must send header: X-Internal-Auth: <this value>
INTERNAL_AUTH_SECRET=change-me-to-a-strong-random-string

# ----- LLM Providers -----
# Gemini (primary for MVP — supports Live API for voice interview)
GEMINI_API_KEY=
GEMINI_MODEL_DEFAULT=gemini-2.0-flash
GEMINI_MODEL_EMBEDDING=text-embedding-004

# OpenAI (fallback / alternative)
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o-mini
OPENAI_MODEL_EMBEDDING=text-embedding-3-small

# Which provider to use by default: "gemini" | "openai"
LLM_PROVIDER_DEFAULT=gemini

# ----- Database (Postgres — same DB as .NET) -----
# NestJS has WRITE access only to AI tables:
#   ai_jobs, ai_requests, ai_results,
#   documents, document_chunks, embedding_jobs,
#   retrieval_logs, ai_tool_calls
# Read-only on the rest.
DATABASE_URL=postgresql://user:password@localhost:5432/skillbridge?schema=public

# ----- Vector Store (pgvector inside the same Postgres) -----
VECTOR_DIMENSION=768
VECTOR_TABLE=document_chunks
VECTOR_COLUMN=embedding

# ----- Observability -----
LOG_LEVEL=debug
ENABLE_REQUEST_LOGGING=true
