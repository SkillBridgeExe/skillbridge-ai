{
  "$note": "Golden cases for the Unified Gap Engine (eval:gap). Each case runs cv_skills + jd_requirements through the REAL SkillNormalizer → SkillDiffService, overlays a fixture evidence ledger, then asserts buildGapItems() produces the expected canonical gap items. Offline, 0 LLM. Data-sanity: every cv_skills name MUST normalize.",
  "version": "eval-gap-cases-v1",
  "created_at": "2026-06-12",
  "cases": [
    {
      "id": "be-mixed-missing-partial-unproven",
      "target_role": "backend_developer",
      "cv_skills": [
        { "name": "SQL", "proficiency_hint": "INTERMEDIATE" },
        { "name": "React", "proficiency_hint": "INTERMEDIATE" }
      ],
      "jd_requirements": [
        { "name": "Kubernetes", "importance_hint": "REQUIRED", "required_level_hint": "ADVANCED" },
        { "name": "SQL", "importance_hint": "REQUIRED", "required_level_hint": "ADVANCED" },
        { "name": "React", "importance_hint": "PREFERRED", "required_level_hint": "INTERMEDIATE" }
      ],
      "ledger_listed_only": ["react"],
      "rationale": "Kubernetes absent → missing/learn. SQL int<adv → partial. React int>=int → matched, but ledger lists it only and cv_level<4 → unproven/add_evidence (an ADVANCED listed-only would instead be overclaimed).",
      "expect": [
        { "canonical": "kubernetes", "cv_status": "missing", "fixability": "learn" },
        { "canonical": "sql", "cv_status": "partial" },
        { "canonical": "react", "cv_status": "unproven", "fixability": "add_evidence", "evidence_risk": "listed_only" }
      ]
    },
    {
      "id": "fe-overclaimed-partial",
      "target_role": "frontend_developer",
      "cv_skills": [{ "name": "React", "proficiency_hint": "ADVANCED" }],
      "jd_requirements": [
        { "name": "React", "importance_hint": "REQUIRED", "required_level_hint": "EXPERT" }
      ],
      "ledger_listed_only": ["react"],
      "rationale": "React claimed ADVANCED (4) but only listed; JD needs EXPERT (5) → partial. Listed-only at >=advanced → overclaimed (interview must probe the advanced claim), not plain partial.",
      "expect": [
        { "canonical": "react", "cv_status": "overclaimed", "fixability": "add_evidence", "evidence_risk": "unproven" }
      ]
    },
    {
      "id": "be-demonstrated-clean-match",
      "target_role": "backend_developer",
      "cv_skills": [
        { "name": "SQL", "proficiency_hint": "ADVANCED" }
      ],
      "jd_requirements": [
        { "name": "SQL", "importance_hint": "REQUIRED", "required_level_hint": "INTERMEDIATE" }
      ],
      "ledger_demonstrated": ["sql"],
      "rationale": "SQL adv>=int + demonstrated in experience → matched, no action, severity 0.",
      "expect": [
        { "canonical": "sql", "cv_status": "matched", "fixability": "not_fixable_now" }
      ]
    },
    {
      "id": "sev-required-missing-outranks-nice-missing",
      "target_role": "backend_developer",
      "cv_skills": [{ "name": "Git", "proficiency_hint": "ADVANCED" }],
      "jd_requirements": [
        { "name": "Kubernetes", "importance_hint": "REQUIRED", "required_level_hint": "ADVANCED" },
        { "name": "Figma", "importance_hint": "NICE_TO_HAVE", "required_level_hint": "ADVANCED" }
      ],
      "rationale": "Both missing at equal gap; a REQUIRED missing skill must outrank a NICE_TO_HAVE one (importance is the outer severity scaler).",
      "expect": [
        { "canonical": "kubernetes", "cv_status": "missing" },
        { "canonical": "figma", "cv_status": "missing" }
      ],
      "expect_severity_order": ["kubernetes", "figma"]
    },
    {
      "id": "sev-overclaimed-outranks-honest-partial",
      "target_role": "backend_developer",
      "cv_skills": [
        { "name": "React", "proficiency_hint": "ADVANCED" },
        { "name": "SQL", "proficiency_hint": "INTERMEDIATE" }
      ],
      "jd_requirements": [
        { "name": "React", "importance_hint": "REQUIRED", "required_level_hint": "EXPERT" },
        { "name": "SQL", "importance_hint": "REQUIRED", "required_level_hint": "ADVANCED" }
      ],
      "ledger_listed_only": ["react"],
      "rationale": "React (adv, listed-only, JD wants expert) → overclaimed partial; SQL (int, honest, JD wants adv) → plain partial. An overclaim the interview will expose outranks an honest small level gap.",
      "expect": [
        { "canonical": "react", "cv_status": "overclaimed" },
        { "canonical": "sql", "cv_status": "partial" }
      ],
      "expect_severity_order": ["react", "sql"]
    }
  ]
}
