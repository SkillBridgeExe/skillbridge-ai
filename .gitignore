!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# IDE - VSCode
.history/*

# Env files
.env
.env.local
.env.*.local
!.env.example

# Local docs (per AGENTS.md convention, .md is local-only except README/AGENTS)
# Uncomment if needed:
# *.md
# !README.md
!AGENTS.md

# Temp
tmp/
temp/

*.md
# prompts/*.md = template runtime (PromptsService load lúc chạy) — PHẢI giữ trong git
!prompts/
!prompts/*.md

# Real-JD seed input (contains posting text + possibly PII pre-scrub) — input-only, NEVER commit
data/jobs-seed.json

# Local embedding-vector cache (eval-semantic re-runs = $0; megabytes of floats, never commit)
data/.cache/

*.dbml

# Raw O*NET / ESCO datasets (large, CC-BY but re-downloadable) — vendor locally, NEVER commit.
# The DERIVED data/onet/*.json (IT subset) IS committed (small, the importer output).
data/onet/*.zip
data/onet/db_*_text/
data/onet/**/*.txt
data/esco/*.zip
data/esco/*.csv
# The DERIVED data/esco/*.json (IT subset + role-skill map) IS committed (small, importer output).

# Eval CV corpus (PII) + derived extractor report — local-only, never commit.
data/eval-cvs-pdf/

# Tesseract OCR language data — downloaded on demand, cached under os.tmpdir() at runtime.
# This guard catches any stray cache written to cwd (e.g. a default-cachePath run).
*.traineddata
