{
  "name": "skillbridge-ai",
  "version": "0.1.0",
  "description": "SkillBridge backend (NestJS modular monolith) - public BFF + internal AI orchestration (CV review, CV/JD matching, mock interview, learning roadmap). Single backend after the 2026-05-30 .NET pivot.",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
    "seed": "ts-node -r tsconfig-paths/register src/database/seed.ts",
    "calibrate": "ts-node -r tsconfig-paths/register src/calibration/calibrate.ts",
    "eval:accuracy": "ts-node -r tsconfig-paths/register src/calibration/eval-accuracy.ts",
    "eval:mentions": "ts-node -r tsconfig-paths/register src/calibration/eval-mentions.ts",
    "eval:match": "ts-node -r tsconfig-paths/register src/calibration/eval-match.ts",
    "eval:rubric": "ts-node -r tsconfig-paths/register src/calibration/eval-rubric.ts",
    "eval:gap": "ts-node -r tsconfig-paths/register src/calibration/eval-gap.ts",
    "taxonomy:validate": "ts-node -r tsconfig-paths/register src/tools/validate-taxonomy.ts",
    "dev": "nest start --watch",
    "eval:semantic": "ts-node -r tsconfig-paths/register src/calibration/eval-semantic.ts",
    "embeddings:backfill": "ts-node -r tsconfig-paths/register src/tools/backfill-skill-embeddings.ts",
    "semantic:smoke": "ts-node -r tsconfig-paths/register src/tools/smoke-semantic.ts",
    "jobs:import": "ts-node -r tsconfig-paths/register src/tools/import-jobs.ts",
    "reco:smoke": "ts-node -r tsconfig-paths/register src/tools/smoke-reco.ts",
    "trends:refresh": "ts-node -r tsconfig-paths/register src/tools/refresh-trends.ts",
    "jobs:crawl": "ts-node -r tsconfig-paths/register src/tools/crawl-jobs.ts",
    "eval:cv-builder": "ts-node -r tsconfig-paths/register src/calibration/eval-cv-builder.ts",
    "cv-files:cleanup": "ts-node -r tsconfig-paths/register src/tools/cleanup-cv-files.ts",
    "payos:webhook:confirm": "ts-node -r tsconfig-paths/register src/tools/confirm-payos-webhook.ts",
    "import:onet": "ts-node src/tools/import-onet-tech-skills.ts",
    "import:esco": "ts-node src/tools/import-esco-it.ts",
    "eval:extractors": "ts-node -r tsconfig-paths/register src/calibration/eval-extractors.ts",
    "eval:ocr-fixture": "ts-node -r tsconfig-paths/register src/calibration/verify-ocr-fixture.ts",
    "eval:cv-parse": "ts-node -r tsconfig-paths/register src/calibration/eval-cv-parse.ts",
    "eval:jd-extract": "ts-node -r tsconfig-paths/register src/calibration/eval-jd-extract.ts",
    "eval:patch": "ts-node -r tsconfig-paths/register src/calibration/eval-patch.ts",
    "eval:proficiency": "ts-node -r tsconfig-paths/register src/calibration/eval-proficiency.ts",
    "eval:cv-signals": "ts-node -r tsconfig-paths/register src/calibration/eval-cv-signals.ts",
    "ab:match-template": "ts-node -r tsconfig-paths/register src/calibration/ab-match-template.ts",
    "report:unnormalized": "ts-node -r tsconfig-paths/register src/calibration/report-unnormalized.ts",
    "calibrate:panel": "ts-node -r tsconfig-paths/register src/calibration/llm-panel.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@google/genai": "^2.7.0",
    "@hyzyla/pdfium": "^2.1.13",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@payos/node": "^2.0.5",
    "@scalar/nestjs-api-reference": "^1.1.19",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.2.0",
    "joi": "^17.13.3",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "openai": "^6.39.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.0",
    "pgvector": "^0.2.1",
    "pngjs": "^7.0.0",
    "puppeteer": "^25.1.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.4",
    "rxjs": "^7.8.1",
    "tesseract.js": "^7.0.0",
    "typeorm": "^0.3.30",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.10",
    "@types/pngjs": "^6.0.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0",
    "unpdf": "^1.6.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "packageManager": "pnpm@11.3.0"
}
